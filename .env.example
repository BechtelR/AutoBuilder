# =============================================================================
# AutoBuilder Environment Configuration
# =============================================================================

# --- LLM Providers (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...                # Primary: Claude models via LiteLLM
OPENAI_API_KEY=sk-...                       # Alternative: OpenAI models
GOOGLE_API_KEY=...                          # Alternative: Gemini models (native ADK)

# --- Database ---
AUTOBUILDER_DB_URL=postgresql+asyncpg://autobuilder:autobuilder@localhost:5432/autobuilder

# --- Redis ---
AUTOBUILDER_REDIS_URL=redis://localhost:6379

# --- Web Search --- (Tavily primary, Brave fallback, optional Firecrawl/SearXNG fallback) ---
AUTOBUILDER_SEARCH_PROVIDER=tavily          # tavily or brave
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=...
# FIRECRAWL_API_KEY=...                     # Optional: Fallback provider, extraction-first crawl
# SEARXNG_URL=http://localhost:8080         # Optional: Dev raw aggregated search, self-hosted

# --- Application ---
AUTOBUILDER_LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR

# --- LLM Router Defaults (see .dev/06-PROVIDERS.md for full model reference) ---
AUTOBUILDER_DEFAULT_CODE_MODEL=anthropic/claude-sonnet-4-6
AUTOBUILDER_DEFAULT_PLAN_MODEL=anthropic/claude-opus-4-6
AUTOBUILDER_DEFAULT_REVIEW_MODEL=anthropic/claude-sonnet-4-6
AUTOBUILDER_DEFAULT_FAST_MODEL=anthropic/claude-haiku-4-5-20251001
